-- Логика переключателя
local freezeEnabled = false
local TWEEN = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

toggleFrame.MouseButton1Click:Connect(function()
	freezeEnabled = not freezeEnabled
	if freezeEnabled then
		TweenService:Create(toggleFrame, TWEEN, {BackgroundColor3 = COLOR_ON}):Play()
		TweenService:Create(knob, TWEEN, {Position = UDim2.new(1, -22, 0.5, -10)}):Play()
		TweenService:Create(statusLabel, TWEEN, {TextColor3 = COLOR_FROZEN}):Play()
		TweenService:Create(statusDot, TWEEN, {BackgroundColor3 = COLOR_FROZEN}):Play()
		statusLabel.Text = "Trade Frozen"
	else
		TweenService:Create(toggleFrame, TWEEN, {BackgroundColor3 = COLOR_OFF}):Play()
		TweenService:Create(knob, TWEEN, {Position = UDim2.new(0, 2, 0.5, -10)}):Play()
		TweenService:Create(statusLabel, TWEEN, {TextColor3 = COLOR_ON}):Play()
		TweenService:Create(statusDot, TWEEN, {BackgroundColor3 = COLOR_ON}):Play()
		statusLabel.Text = "Ready"
	end

	-- >>> Здесь твоя логика <
	print("Freeze Trade:", freezeEnabled)
end)

